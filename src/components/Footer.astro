---
interface Props {
  id?: string;
}
const { id } = Astro.props;

import { sanityClient, isSanityConfigured } from '../lib/sanity';

const hasSanity = isSanityConfigured;
let gigs = [];

if (hasSanity) {
  try {
    gigs = await sanityClient.fetch(`*[_type == "post" && postType == "gig" && !isPast] | order(date asc)[0...3]`);
  } catch (err) {
    console.error("Sanity fetch error for footer gigs:", err);
  }
}

const fallbackGigs = [
  { city: 'Berlin', date: '2026-10-12' },
  { city: 'London', date: '2026-11-05' },
  { city: 'New York', date: '2026-12-01' }
];

const gigsToShow = gigs.length > 0 ? gigs : fallbackGigs;

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const parts = dateStr.split('-');
  if (parts.length !== 3) return dateStr;
  const [year, month, day] = parts;
  return `${day}.${month}.${year}`;
}
---
<!-- ===================== FOOTER ===================== -->
<footer id={id}>
  <div class="foot-grid">
    <div>
      <span class="micro" data-en="On the road" data-de="Unterwegs">On the road</span>
      {gigsToShow.map((gig) => (
        <a class="clock-row" href={gig._id ? `/gigs#${gig._id}` : '/gigs'} style="text-decoration: none; color: inherit; display: flex; justify-content: space-between; align-items: center;">
          <span style="font-weight: 500; font-family: 'Inter Tight', sans-serif;">{gig.city}</span>
          <span style="color: var(--muted); font-variant-numeric: tabular-nums; margin-left: 12px; font-size: 13px; flex-shrink: 0;">{formatDate(gig.date)}</span>
        </a>
      ))}
    </div>
    <div>
      <span class="micro" data-en="Booking" data-de="Booking">Booking</span>
      <a class="mail email-protect" data-user="hi" data-domain="skippingmondays.com">hi [at] skippingmondays.com</a>
    </div>
    <div>
      <span class="micro" data-en="Mailing list" data-de="Newsletter">Mailing list</span>
      <form class="newsletter" action="/api/subscribe" method="POST"
            data-ok-en="You're in! No Monday emails, promise." data-ok-de="Du bist dabei! Keine Montags-Mails, versprochen."
            data-err-en="That didn't work — try again?" data-err-de="Hat nicht geklappt — nochmal versuchen?"
            data-off-en="Signup isn't connected yet." data-off-de="Anmeldung ist noch nicht verbunden.">
        <div class="nl-row">
          <input type="email" name="email" required placeholder="you@example.com" aria-label="Email address">
          <button type="submit" aria-label="Subscribe">→</button>
        </div>
        <input type="text" name="_gotcha" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true">
        <p class="nl-note" data-en="Gig alerts &amp; new releases. Never on a Monday." data-de="Konzert-Alarm &amp; neue Releases. Nie montags.">Gig alerts &amp; new releases. Never on a Monday.</p>
        <p class="form-status" role="status"></p>
      </form>
    </div>
    <div>
      <span class="micro" data-en="Follow" data-de="Folgen">Follow</span>
      <ul>
        <li><a href="#">Instagram</a></li>
        <li><a href="#">TikTok</a></li>
        <li><a href="#">Spotify</a></li>
        <li><a href="#">YouTube</a></li>
      </ul>
    </div>
  </div>

  <div class="giant-wrap">
