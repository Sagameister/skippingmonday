---
interface Props {
  id?: string;
}
const { id } = Astro.props;
---
<!-- ===================== FOOTER ===================== -->
<footer id={id}>
  <div class="foot-grid">
    <div>
      <span class="micro" data-en="On the road" data-de="Unterwegs">On the road</span>
      <div class="clock-row"><span>Berlin</span>   <time id="clock-berlin">--:--</time></div>
      <div class="clock-row"><span>London</span>   <time id="clock-london">--:--</time></div>
      <div class="clock-row"><span>New York</span> <time id="clock-ny">--:--</time></div>
    </div>
    <div>
      <span class="micro" data-en="Booking" data-de="Booking">Booking</span>
      <a class="mail email-protect" data-user="booking" data-domain="skippingmondays.example">booking [at] skippingmondays.example</a>
      <p style="margin-top:18px; font-size:13px; color:var(--muted);">
        <span data-en="Management: Mel Okafor" data-de="Management: Mel Okafor">Management: Mel Okafor</span>
      </p>
    </div>
    <div>
      <span class="micro" data-en="Mailing list" data-de="Newsletter">Mailing list</span>
      <form class="newsletter" action="https://formspree.io/f/YOUR_NEWSLETTER_ID" method="POST"
            data-ok-en="You're in! No Monday emails, promise." data-ok-de="Du bist dabei! Keine Montags-Mails, versprochen."
            data-err-en="That didn't work — try again?" data-err-de="Hat nicht geklappt — nochmal versuchen?"
            data-off-en="Signup isn't connected yet." data-off-de="Anmeldung ist noch nicht verbunden.">
        <div class="nl-row">
          <input type="email" name="email" required placeholder="you@example.com" aria-label="Email address">
          <button type="submit" aria-label="Subscribe">→</button>
        </div>
        <input type="text" name="_gotcha" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true">
        <p class="nl-note" data-en="Gig alerts &amp; new releases. Never on a Monday." data-de="Konzert-Alarm &amp; neue Releases. Nie montags.">Gig alerts &amp; new releases. Never on a Monday.</p>
        <p class="form-status" role="status"></p>
      </form>
    </div>
    <div>
      <span class="micro" data-en="Follow" data-de="Folgen">Follow</span>
      <ul>
        <li><a href="#">Instagram</a></li>
        <li><a href="#">TikTok</a></li>
        <li><a href="#">Spotify</a></li>
        <li><a href="#">YouTube</a></li>
      </ul>
    </div>
  </div>

  <div class="giant-wrap">
    <svg class="giant" viewBox="0 0 960 78" aria-label="Skipping Mondays">
      <defs>
        <radialGradient id="rainbow" gradientUnits="userSpaceOnUse"
                        cx="480" cy="220" r="260" spreadMethod="repeat">
          <stop offset="0.000" stop-color="#3D7BE8"/>
          <stop offset="0.143" stop-color="#A78BE8"/>
          <stop offset="0.286" stop-color="#6B2C91"/>
          <stop offset="0.429" stop-color="#E63B2E"/>
          <stop offset="0.571" stop-color="#F58220"/>
          <stop offset="0.714" stop-color="#9FBF3B"/>
          <stop offset="0.857" stop-color="#2E8C7A"/>
          <stop offset="1.000" stop-color="#3D7BE8"/>
          <animate id="rainbow-anim-r" attributeName="r"
                   values="260;380;260" dur="8s" repeatCount="indefinite"/>
        </radialGradient>
      </defs>
      <text x="0" y="72" textLength="960" lengthAdjust="spacingAndGlyphs">SKIPPING MONDAYS</text>
      <text class="giant-rainbow" aria-hidden="true"
            x="0" y="72" textLength="960" lengthAdjust="spacingAndGlyphs">SKIPPING MONDAYS</text>
    </svg>
  </div>

  <div class="legal">
    <span>© 2026 Skipping Mondays</span>
    <span>
      <a href="/privacy" data-en="Privacy Policy" data-de="Datenschutz">Privacy Policy</a>
      &nbsp;·&nbsp;
      <a href="/imprint" data-en="Imprint" data-de="Impressum">Imprint</a>
    </span>
  </div>
</footer>
