---
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/styles.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <Head title={title} />
  <body>
    <Header />
    <slot />
    <Footer />

    <!-- Video Lightbox Modal -->
    <div id="video-lightbox" class="video-lightbox" aria-hidden="true" role="dialog">
      <button class="v-close-btn" aria-label="Close video player">&times;</button>
      <div class="v-lightbox-content">
        <div class="v-wrapper">
          <iframe id="v-lightbox-iframe" src="" allow="autoplay; encrypted-media" allowfullscreen></iframe>
        </div>
      </div>
    </div>

    <script is:inline src="/site.js"></script>
  </body>
</html>
