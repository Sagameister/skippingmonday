---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ticker from '../components/Ticker.astro';
---
<BaseLayout title="About — Skipping Mondays">
  <!-- ===================== PAGE HERO ===================== -->
  <div class="page-hero">
    <img src="/Images/hero.jpg" alt="The band on stage at soundcheck">
    <h1 class="page-title" data-split data-en="About the Band" data-de="Über die Band">About the Band</h1>
  </div>

  <main class="page-main">
    <div class="bio-block">
      <p data-en="Skipping Mondays started the way most bad ideas and all good bands do: four strangers, one borrowed rehearsal room, and a shared suspicion that the week begins one day too early."
         data-de="Skipping Mondays begann wie die meisten schlechten Ideen und alle guten Bands: vier Fremde, ein geliehener Proberaum und der gemeinsame Verdacht, dass die Woche einen Tag zu früh beginnt.">
         Skipping Mondays started the way most bad ideas and all good bands do: four strangers, one borrowed rehearsal room, and a shared suspicion that the week begins one day too early.</p>
      <p data-en="We come from four hometowns on three continents — Hanoi, New York, Mexico City, and the German Rhineland — and it shows: warm synths argue with loud guitars, honest words settle it."
         data-de="Wir kommen aus vier Heimatorten auf drei Kontinenten — Hanoi, New York, Mexiko-Stadt und dem Rheinland — und man hört es: Warme Synths streiten mit lauten Gitarren, ehrliche Worte schlichten.">
         We come from four hometowns on three continents — Hanoi, New York, Mexico City, and the German Rhineland — and it shows: warm synths argue with loud guitars, honest words settle it.</p>
      <p data-en="We have exactly one rule, and it is in the name."
         data-de="Wir haben genau eine Regel, und sie steht im Namen.">
         We have exactly one rule, and it is in the name.</p>
    </div>

    <!-- the hometown ticker -->
    <Ticker />

    <div class="sub-head">
      <h3 class="subtitle" data-split data-en="The band" data-de="Die Band">The band</h3>
    </div>
    <div class="members">
      <figure class="member" data-reveal>
        <div class="m-photo reveal-img"><img src="https://picsum.photos/seed/member1/700/933" alt="An Nguyen"></div>
        <h3>An Nguyen</h3>
        <span class="micro" data-en="Vocals · Hanoi" data-de="Gesang · Hanoi">Vocals · Hanoi</span>
      </figure>
      <figure class="member" data-reveal>
        <div class="m-photo reveal-img"><img src="https://picsum.photos/seed/member2/700/933" alt="Maya Brooks"></div>
        <h3>Maya Brooks</h3>
        <span class="micro" data-en="Synths · New York" data-de="Synths · New York">Synths · New York</span>
      </figure>
      <figure class="member" data-reveal>
        <div class="m-photo reveal-img"><img src="https://picsum.photos/seed/member3/700/933" alt="Diego Ramírez"></div>
        <h3>Diego Ramírez</h3>
        <span class="micro" data-en="Bass · Mexico City" data-de="Bass · Mexiko-Stadt">Bass · Mexico City</span>
      </figure>
      <figure class="member" data-reveal>
        <div class="m-photo reveal-img"><img src="https://picsum.photos/seed/member4/700/933" alt="Jonas Weber"></div>
        <h3>Jonas Weber</h3>
        <span class="micro" data-en="Guitar · Köln" data-de="Gitarre · Köln">Guitar · Köln</span>
      </figure>
    </div>
  </main>
</BaseLayout>
