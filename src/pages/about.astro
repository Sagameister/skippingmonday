---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ticker from '../components/Ticker.astro';
---
<BaseLayout title="About — Skipping Mondays">
  <!-- ===================== PAGE HERO ===================== -->
  <div class="page-hero">
    <img src="/Images/hero.jpg" alt="The band on stage at soundcheck">
    <h1 class="page-title" data-split data-en="About the Band" data-de="Über die Band">About the Band</h1>
  </div>

  <main class="page-main">
    <div class="bio-block">
      <p data-en="Skipping Mondays started the way most bad ideas and all good bands do: four strangers, one borrowed rehearsal room, and a shared suspicion that the week begins one day too early."
         data-de="Skipping Mondays begann wie die meisten schlechten Ideen und alle guten Bands: vier Fremde, ein geliehener Proberaum und der gemeinsame Verdacht, dass die Woche einen Tag zu früh beginnt.">
         Skipping Mondays started the way most bad ideas and all good bands do: four strangers, one borrowed rehearsal room, and a shared suspicion that the week begins one day too early.</p>
      <p data-en="We come from four hometowns on three continents — Hanoi, New York, Mexico City, and the Bruchsal area in Germany — and it shows: warm synths argue with loud guitars, honest words settle it."
         data-de="Wir kommen aus vier Heimatorten auf drei Kontinenten — Hanoi, New York, Mexiko-Stadt und dem Raum Bruchsal in Deutschland — und man hört es: Warme Synths streiten mit lauten Gitarren, ehrliche Worte schlichten.">
         We come from four hometowns on three continents — Hanoi, New York, Mexico City, and the Bruchsal area in Germany — and it shows: warm synths argue with loud guitars, honest words settle it.</p>
      <p data-en="We have exactly one rule, and it is in the name."
         data-de="Wir haben genau eine Regel, und sie steht im Namen.">
         We have exactly one rule, and it is in the name.</p>
    </div>

    <!-- the hometown ticker -->
    <Ticker />

    <div class="sub-head">
      <h3 class="subtitle" data-split data-en="The band" data-de="Die Band">The band</h3>
    </div>
    <div class="members">
      <figure class="member" data-reveal>
        <div class="m-photo reveal-img"><img src="/Images/contact-hero.jpg" alt="Linh Hoang"></div>
        <h3>Linh Hoang</h3>
        <span class="micro" data-en="Lead Vocals · Hanoi" data-de="Gesang · Hanoi">Lead Vocals · Hanoi</span>
      </figure>
      <figure class="member" data-reveal>
        <div class="m-photo reveal-img"><img src="https://picsum.photos/seed/member2/700/933" alt="Hyun Lee"></div>
        <h3>Hyun Lee</h3>
        <span class="micro" data-en="Lead Guitar, Keyboards, Vocals · New York" data-de="Lead-Gitarre, Keyboards, Gesang · New York">Lead Guitar, Keyboards, Vocals · New York</span>
      </figure>
      <figure class="member" data-reveal>
        <div class="m-photo reveal-img"><img src="https://picsum.photos/seed/member3/700/933" alt="Willy Schmitz"></div>
        <h3>Willy Schmitz</h3>
        <span class="micro" data-en="Bass · Germany" data-de="Bass · Deutschland">Bass · Germany</span>
      </figure>
      <figure class="member" data-reveal>
        <div class="m-photo reveal-img"><img src="https://picsum.photos/seed/member4/700/933" alt="Ed Dominguez"></div>
        <h3>Ed Dominguez</h3>
        <span class="micro" data-en="Drums, Percussions, and vocals · Mexico" data-de="Schlagzeug, Percussion, Gesang · Mexiko">Drums, Percussions, and vocals · Mexico</span>
      </figure>
    </div>
  </main>
</BaseLayout>
