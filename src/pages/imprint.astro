---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Imprint — Skipping Mondays">
  <main class="page-main" style="padding-top: 18vh; max-width: 800px; margin: 0 auto;">
    <h1 class="page-title" data-split data-en="Imprint" data-de="Impressum" style="margin-bottom: 40px;">Imprint</h1>
    
    <div style="font-size: 16px; line-height: 1.8; color: var(--cream);">
      <section style="margin-bottom: 40px; padding: 0;">
        <h2 style="font-size: 24px; margin-bottom: 16px;" data-en="Information according to § 5 TMG" data-de="Angaben gemäß § 5 TMG">Information according to § 5 TMG</h2>
        <p>
          <strong>Skipping Mondays GbR</strong><br />
          c/o Jonas Weber<br />
          Belgisches Viertel<br />
          50672 Köln<br />
          Germany
        </p>
      </section>

      <section style="margin-bottom: 40px; padding: 0;">
        <h2 style="font-size: 24px; margin-bottom: 16px;" data-en="Represented by" data-de="Vertreten durch">Represented by</h2>
        <p>
          An Nguyen, Maya Brooks, Diego Ramírez, Jonas Weber
        </p>
      </section>

      <section style="margin-bottom: 40px; padding: 0;">
        <h2 style="font-size: 24px; margin-bottom: 16px;" data-en="Contact" data-de="Kontakt">Contact</h2>
        <p data-en="Email: hi [at] skippingmondays.com (see Contact page for details)"
           data-de="E-Mail: hi [at] skippingmondays.com (Details siehe Kontaktseite)">
           Email: hi [at] skippingmondays.com (see Contact page for details)
        </p>
      </section>
    </div>
  </main>
</BaseLayout>
