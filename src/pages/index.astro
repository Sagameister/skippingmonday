/* giant wordmark at the very bottom — ALWAYS exactly 100% width.
   It's an SVG <text>, and SVGs scale like images: the drawing
   area (viewBox) is 960 units wide, textLength stretches the
   text to fill all 960, and the SVG itself is width:100%.
   Result: edge-to-edge on every screen, no JavaScript needed. */
.giant-wrap{ overflow:hidden; }   /* the "mask" for the reveal animation */
svg.giant{
  display:block;
  width:100%;                     /* fill the row... */
  height:auto;                    /* ...and keep the proportions */
}
svg.giant path{
