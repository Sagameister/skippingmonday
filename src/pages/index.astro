     one from the top (so the navbar is readable over any photo) */
  background:
    linear-gradient(to top, rgba(0,0,0,.45), rgba(0,0,0,.05) 45%),
    linear-gradient(to bottom, rgba(0,0,0,.45), rgba(0,0,0,0) 22%);
}
.hero .cycle{
