gsap.utils.toArray('.news-row').forEach((row) => {
  gsap.from(row, {
    scrollTrigger: { trigger: row, start: 'top 95%', once: true },
    opacity: 0, y: 16, duration: .9, ease: 'brand'
  });
});
gsap.utils.toArray('.btn-all').forEach((btn) => {
  gsap.from(btn, {
    scrollTrigger: { trigger: btn, start: 'top 95%', once: true },
    opacity: 0, y: 16, duration: .9, ease: 'brand'
  });
});

// small section labels: opacity-only, settle at 70% (Pattern 7)
gsap.utils.toArray('.section-head .micro').forEach((label) => {
  gsap.fromTo(label, { opacity: 0 }, {
    scrollTrigger: { trigger: label, start: 'top 85%', once: true },
    opacity: .7, duration: .8, ease: 'brand'
  });
});

// --- MEDIA (Pattern 4): every image opens like a window ---------
// (applies to photo collage AND video thumbnails, on all screens)
gsap.utils.toArray('.photo-track .ph img, .video-grid .v-thumb img').forEach((img) => {
  gsap.fromTo(img,
    { clipPath: 'inset(20% 20% 20% 20%)', opacity: 0 },
    {
      scrollTrigger: { trigger: img, start: 'top 85%', once: true },
      clipPath: 'inset(0% 0% 0% 0%)', opacity: 1,
      duration: 1.4, ease: 'brand'   // longer — images are focal points
    });
});

// giant wordmark: it's an SVG (not text spans), so it gets one
// big mask reveal — the whole line rises out of its wrapper
gsap.from('svg.giant', {
  scrollTrigger: { trigger: '.giant-wrap', start: 'top 92%', once: true },
  yPercent: 100, duration: 1.4, ease: 'brand'
});

}  // end of the reduced-motion guard

/* ============================================================
   TEXT-ROLL HOVER — builder
   Wraps the text of every link/button in the two-copy roll
   structure (see the CSS comment). Runs at load and again after
   every language switch (which resets elements to plain text).
   ============================================================ */
const ROLL_TARGETS = [
  'header nav a.nav-link',   // top navigation
  '.menu-links .m-inner',    // burger menu links
  '.lang button',            // DE / EN pills
  '.btn-all',                // "See all news"
  '.news-row .n-title',      // news headlines (rolls on row hover)
  '.foot-grid ul a',         // social links
  '.legal a'                 // privacy / imprint
];

function buildRoll(el){
  if (el.querySelector('.roll-inner')) return;   // already wrapped
  const text = el.textContent.trim();
  if (!text) return;
  el.textContent = '';                           // clear, then rebuild safely
  const roll  = document.createElement('span');  roll.className  = 'roll';
  const inner = document.createElement('span');  inner.className = 'roll-inner';
  for (let i = 0; i < 2; i++){
    const line = document.createElement('span');
    line.className = 'roll-line';
    line.textContent = text;                     // two identical copies
    if (i === 1) line.setAttribute('aria-hidden', 'true');  // screen readers read it once
    inner.appendChild(line);
  }
  roll.appendChild(inner);
  el.appendChild(roll);
  // hover is detected on the clickable parent (link or button)
  (el.closest('a,button') || el).classList.add('has-roll');
}

function buildAllRolls(){
  document.querySelectorAll(ROLL_TARGETS.join(',')).forEach(buildRoll);
}
buildAllRolls();   // wrap everything once on load

// Easter egg housekeeping: if the user prefers reduced motion,
// remove the rainbow's looping animation — hovering the wordmark
// then shows a STATIC rainbow instead of a scrolling one
if (prefersReduced){
  const a = document.getElementById('rainbow-anim-r');
  if (a) a.remove();
}

/* ============================================================
   EASTER EGG 2.0 — the rainbow's bullseye chases the cursor.
   Every frame it moves 7% of the remaining distance toward the
   pointer. Never all the way at once — THAT'S the lag. Leave
   the wordmark and it drifts home the same way.
   ============================================================ */
const rainbowGrad = document.getElementById('rainbow');
const giantWrap   = document.querySelector('.giant-wrap');
const giantSvg    = document.querySelector('svg.giant');
const rainbowPos  = { x: 480, y: 220 };   // where the center IS right now
const rainbowAim  = { x: 480, y: 220 };   // where it WANTS to be

if (!prefersReduced && rainbowGrad && giantWrap){
  giantWrap.addEventListener('mousemove', (e) => {
    // convert screen pixels into the SVG's own 960×78 grid
    const r = giantSvg.getBoundingClientRect();
    rainbowAim.x = (e.clientX - r.left) / r.width  * 960;
    rainbowAim.y = (e.clientY - r.top)  / r.height * 78;
  });
  giantWrap.addEventListener('mouseleave', () => {
    rainbowAim.x = 480;                   // drift back to the resting center
    rainbowAim.y = 220;
  });
  // gsap.ticker = "run this ~60× per second", same clock as everything else
  gsap.ticker.add(() => {
    rainbowPos.x += (rainbowAim.x - rainbowPos.x) * 0.035;   // lower = dreamier lag
    rainbowPos.y += (rainbowAim.y - rainbowPos.y) * 0.035;
    rainbowGrad.setAttribute('cx', rainbowPos.x);
    rainbowGrad.setAttribute('cy', rainbowPos.y);
  });
}

/* ============================================================
   NEWS HOVER THUMBNAIL
   One floating image chases the cursor over the news rows —
   each frame it covers 12% of the remaining distance (the lag).
   Entering a row swaps in that row's picture; leaving hides it.
   ============================================================ */
const hoverThumb    = document.querySelector('.hover-thumb');
const hoverThumbImg = hoverThumb.querySelector('img');
const thumbPos = { x: 0, y: 0 };   // where the preview IS
const thumbAim = { x: 0, y: 0 };   // where it WANTS to be

if (!prefersReduced && window.matchMedia('(hover: hover)').matches){
  gsap.ticker.add(() => {
    thumbPos.x += (thumbAim.x - thumbPos.x) * 0.12;
    thumbPos.y += (thumbAim.y - thumbPos.y) * 0.12;
    gsap.set(hoverThumb, { x: thumbPos.x, y: thumbPos.y });
  });

  document.querySelectorAll('.news-row, #gigs .gig').forEach((row) => {
    row.addEventListener('mouseenter', (e) => {
      hoverThumbImg.src = row.dataset.thumb;      // this row's picture
      // start AT the cursor so it doesn't fly in from across the page
      thumbAim.x = thumbPos.x = e.clientX + 32;
      thumbAim.y = thumbPos.y = e.clientY - 120;
      hoverThumb.classList.add('on');
    });
    row.addEventListener('mousemove', (e) => {
      thumbAim.x = e.clientX + 32;                // float up-right of the cursor
      thumbAim.y = e.clientY - 120;
    });
    row.addEventListener('mouseleave', () => {
      hoverThumb.classList.remove('on');          // fade away
    });
  });
}

/* ============================================================
   PHOTO SLIDER
   Several photos visible at once; every few seconds the track
   glides one photo further. Arrows do the same by hand. On
   phones (≤760px) the CSS stacks everything vertically and this
   code simply stays dormant.
   ============================================================ */
const photoTrack = document.querySelector('.photo-track');
const photoView  = document.querySelector('.photo-viewport');
const photoItems = gsap.utils.toArray('.photo-track .ph');
let slideIndex = 0;
let slideTimer = null;

const sliderActive = () => window.innerWidth > 760;   // phones: no slider

// the furthest the track can shift before showing empty space
function maxSlideX(){
  return Math.max(0, photoTrack.scrollWidth - photoView.clientWidth);
}

function slideTo(i){
  if (!sliderActive()) return;
  const max = maxSlideX();
  if (max === 0) return;                     // everything already fits
  // the last photo worth stopping at (further ones would show a gap)
  let last = photoItems.findIndex((p) => p.offsetLeft >= max);
  if (last === -1) last = photoItems.length - 1;
  // wrap around at both ends
  if (i > last) i = 0;
  if (i < 0)    i = last;
  slideIndex = i;
  const x = Math.min(photoItems[i].offsetLeft, max);
  gsap.to(photoTrack, {
    x: -x,
    duration: prefersReduced ? 0 : 1.1,
    ease: 'brand'
  });
}
const nextSlide = () => slideTo(slideIndex + 1);
const prevSlide = () => slideTo(slideIndex - 1);

// auto-advance every 4.5s (not for reduced-motion users)
function startAuto(){
  stopAuto();
  if (prefersReduced || !sliderActive()) return;
  slideTimer = setInterval(nextSlide, 4500);
}
function stopAuto(){
  if (slideTimer){ clearInterval(slideTimer); slideTimer = null; }
}

// arrows: slide AND restart the auto timer (so it doesn't fight you)
document.querySelector('.slide-btn.next').addEventListener('click', () => { nextSlide(); startAuto(); });
document.querySelector('.slide-btn.prev').addEventListener('click', () => { prevSlide(); startAuto(); });

// pause while the cursor is over the photos — polite, not pushy
const photoSlider = document.querySelector('.photo-slider');
photoSlider.addEventListener('mouseenter', stopAuto);
photoSlider.addEventListener('mouseleave', startAuto);

// window resized across the phone boundary? reset cleanly
addEventListener('resize', () => {
  if (!sliderActive()){
    stopAuto();
    slideIndex = 0;
    gsap.set(photoTrack, { x: 0 });
  } else if (!slideTimer){
    startAuto();
  }
});
startAuto();



// newsletter signup: honeypot + "not connected yet" notice + fetch
// (same recipe as the contact page form — see site.js for details)
document.querySelectorAll('.newsletter').forEach((form) => {
  const statusEl = form.querySelector('.form-status');
  const msg = (key) => form.dataset[key + (currentLang === 'de' ? 'De' : 'En')] || '';
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (form.querySelector('[name="_gotcha"]').value) return;   // bot
    if (form.action.includes('YOUR_')){ statusEl.textContent = msg('off'); return; }
    try {
      const res = await fetch(form.action, {
        method: 'POST', body: new FormData(form),
        headers: { 'Accept': 'application/json' }
      });
      if (res.ok){ form.reset(); statusEl.textContent = msg('ok'); }
      else       { statusEl.textContent = msg('err'); }
    } catch (_){ statusEl.textContent = msg('err'); }
  });
});

// spam-safe email links: assemble user@domain at load time so the
// address never appears complete in the HTML source (see site.js)
document.querySelectorAll('.email-protect').forEach((a) => {
  const addr = a.dataset.user + '@' + a.dataset.domain;
  a.textContent = addr;
  a.setAttribute('href', 'mailto:' + addr);
});

updateHeaderTheme();             // set the correct navbar theme on load

// restore the language chosen on another page (if any)
try {
  const savedLang = localStorage.getItem('sm-lang');
  if (savedLang && savedLang !== 'en') setLang(savedLang);
} catch(e){}

// park the menu curtain in its raised position, ready to animate.
// (translateY(-100%) is in the CSS too — this hands control to GSAP)
gsap.set(menuOverlay, { y: 0, yPercent: -100, autoAlpha: 0 });

// (The old JS that measured and resized the footer wordmark is gone —
//  the SVG version scales itself, so no code is needed anymore.)
</script>
</body>
</html>
