}

/* ============================================================
   STATEMENT — the big quiet headline
   ("Let's raise your idea." on the reference)
   ============================================================ */
.statement{
  position:relative;
  padding: 22vh 3vw 14vh;
  overflow: hidden;
}
#dust-canvas{                  /* subtle three.js particles live back here */
  position:absolute; inset:0;
