<!DOCTYPE html>
<html lang="en">
<Head title="Skipping Mondays — Official Site" loadThree={true} />

<style is:global>
/* ============================================================
   THE LOOK
   Mimics the Bennett & Clive aesthetic:
   white page, black text, lots of air, tiny uppercase labels,
   one huge quiet headline, editorial photo collage.
   ============================================================ */
:root{
  --white: #ffffff;
  --black: #111111;
  --gray:  #8a8a8a;          /* for small secondary labels */
  --line:  #e5e5e5;          /* hairline borders */
  --cream: #FFF8F0;          /* warm white — text on dark sections */
}

*{ margin:0; padding:0; box-sizing:border-box; }
/* NOTE: no `scroll-behavior:smooth` here — the Lenis library
   takes over ALL scrolling and the two would fight each other */

body{
  background: var(--white);
  color: var(--black);
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  line-height: 1.5;
  overflow-x: hidden;
}

a{ color: inherit; text-decoration: none; }
img{ display:block; width:100%; height:100%; object-fit:cover; }

/* ============================================================
   SPLIT-TEXT MASKS
   JavaScript wraps every word of a headline in two spans:
   <span class="w-mask"><span class="w-inner">word</span></span>
   The outer span is a "letterbox" (overflow:hidden). The inner
   span starts pushed below it, then slides up into view —
   so each word appears as if rising out of a slot.
   ============================================================ */
.w-mask{
  display:inline-block;
  overflow:hidden;              /* the mask: hides whatever is pushed below */
  vertical-align:top;
  /* tight line-heights clip letters like g/p/y — this padding trick
     extends the mask downward without changing the layout */
  padding-bottom:.22em;   /* room for deep descenders like y, g, p */
  margin-bottom:-.22em;   /* cancels the padding so layout doesn't shift */
  padding-right:.08em;    /* room for italics/letter-spacing clipping */
  margin-right:-.08em;    /* cancels the padding so layout doesn't shift */
}
.w-inner{ display:inline-block; will-change: transform; }

/* the tiny uppercase label style used everywhere on the reference site */
.micro{
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--gray);
}

/* ============================================================
   HEADER — thin fixed bar: wordmark left, nav + language right
   ============================================================ */
header{
  position: fixed;
  top:0; left:0; right:0;
  z-index: 20;
  display:flex;
  justify-content: space-between;
  align-items:center;
  padding: 20px 3vw;
  /* THEME SYSTEM: one variable controls every color in the bar.
     Default = white (over the hero photo). JS adds .dark once you
     scroll past the hero, flipping everything to black. */
  --nav-ink: #fff;          /* text/lines color */
  --nav-contrast: #111;     /* color used on top of --nav-ink (active pill) */
  color: var(--nav-ink);
  transition: color .35s;
}
header.dark{
  --nav-ink: #111;
  --nav-contrast: #fff;
}
header .wordmark{ display:flex; align-items:center; }
header .wordmark img{
  height: 54px;          /* controls the logo size — width scales with it */
  width: auto;
  display:block;
  transition: filter .35s;
}
/* the SVG file is white; invert(1) flips it to black on light sections */
header.dark .wordmark img{ filter: invert(1); }
header nav{ display:flex; align-items:center; gap: 44px; }
header nav a.nav-link{
  color: var(--nav-ink);
  transition: color .35s;
  font-family:'Inter Tight', sans-serif;
  /* EXAGGERATED: scales with the screen, 18px → 30px */
  font-size: clamp(18px, 1.8vw, 30px);
  font-weight: 600;              /* semi-bold */
  text-transform: uppercase;     /* ALL CAPS */
  letter-spacing: -0.02em;       /* tight kerning, matches the headlines */
  position:relative;
}
/* underline that grows on hover — subtle, like the reference */
header nav a.nav-link::after{
  content:'';
  position:absolute;
  left:0; bottom:-4px;
  width:0%; height:2px;          /* thicker line for the bolder links */
  background: var(--nav-ink);
  transition: width .3s;
}
header nav a.nav-link:hover::after{ width:100%; }

/* --- language switcher: shows ONLY the active language.
       Tapping it drops down the other one; picking that swaps. --- */
.lang{ position:relative; }
.lang button{
  border:1px solid var(--nav-ink);
  background:transparent;
  color: var(--nav-ink);
  transition: color .35s, border-color .35s, background .35s;
  font-family:'Inter',sans-serif;
  font-size:13px;
  font-weight:600;
  letter-spacing:.1em;
  padding: 7px 16px;
  border-radius: 100px;
  cursor:pointer;
}
.lang-menu{
  position:absolute;
  top: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%);
  display:none;                        /* hidden until .lang gets .open */
}
.lang.open .lang-menu{ display:block; }
/* the dropdown uses the theme's INVERSE color as its background,
   so it's readable over the hero photo AND over white sections */
.lang-menu button{
  background: var(--nav-contrast);
  color: var(--nav-ink);
}

/* --- burger button (hidden on desktop, shown on tablet/mobile) --- */
.burger{
  display:none;                  /* desktop: invisible */
  background:transparent;
  border:none;
  cursor:pointer;
  width:44px; height:44px;       /* generous tap target */
  padding:6px;
}
.burger span{
  display:block;
  width:30px; height:2px;
  background: var(--nav-ink);
  margin:9px auto;
  transition: transform .35s ease, opacity .35s ease;
}
/* when open, the two lines rotate into an X */
.burger.open span:nth-child(1){ transform: translateY(5.5px) rotate(45deg); }
.burger.open span:nth-child(2){ transform: translateY(-5.5px) rotate(-45deg); }

/* --- the full-screen menu itself --- */
.menu-overlay{
  position:fixed; inset:0;
  z-index:15;                    /* above the page, below the header bar */
  background:#111;
  padding: 18vh 6vw 8vh;
  /* hidden by default (visibility only!). GSAP parks it one
     screen-height up and slides it like a curtain. IMPORTANT: no
     CSS transform here — GSAP must own the transform, otherwise
     the CSS offset and GSAP's offset add up and the menu animates
     entirely off-screen (that bug already bit us once). */
  visibility:hidden;
}
.menu-links{ display:flex; flex-direction:column; gap:1.5vh; }
.menu-links a{
  color:#fff;
  font-family:'Inter Tight',sans-serif;
  font-weight:600;
  text-transform:uppercase;
  font-size: clamp(3rem, 11vw, 7rem);   /* HUGE stacked links */
  line-height:1.05;
  letter-spacing:-0.02em;
  width:fit-content;
}
.menu-links a:hover{ color:#8a8a8a; }
/* each link sits in a little mask so it can rise in when the menu opens */
.m-mask{ display:inline-block; overflow:hidden; padding-bottom:.15em; margin-bottom:-.15em; }
.m-inner{ display:inline-block; }

/* --- NEWS rows: quiet list, echoes the gigs table --- */
.news-row{
  display:grid;
  grid-template-columns: 1fr auto auto;   /* headline | date | arrow */
  gap: 24px;
  align-items: center;
  padding: 26px 0;
  border-top: 1px solid rgba(255,248,240,.18);
  transition: opacity .25s;
}
.news-row:last-of-type{ border-bottom: 1px solid rgba(255,248,240,.18); }
/* same editorial trick as gigs: dim the rows you're not on */
.news-list:hover .news-row{ opacity:.35; }
.news-list:hover .news-row:hover{ opacity:1; }
.n-date{ font-size:13px; color:#9a9a9a; }
.n-title{
  font-family:'Inter Tight',sans-serif;
  font-weight:500;
  font-size: clamp(1.6rem, 3.2vw, 2.8rem);
  letter-spacing:-0.02em;
}
/* headline rolls must stay on one line (the mask is one line tall) */
.n-title .roll{ white-space:nowrap; max-width:100%; }
/* the arrow's sideways letterbox: exactly one arrow wide */
.n-arrow{
  font-size: 24px;
  overflow: hidden;               /* the mask */
  width: 1.3em;
}
.n-arrow .a-inner{
  display:flex;
  width: 200%;                    /* two arrows side by side */
  transform: translateX(-50%);    /* at rest: show the right-hand copy */
  transition: transform .45s cubic-bezier(0.22, 1, 0.36, 1);
}
.n-arrow .a-inner span{ flex:0 0 50%; text-align:center; }
/* hover: the visible arrow exits right, its twin rolls in from the left */
.news-row:hover .a-inner{ transform: translateX(0); }
/* --- the cursor-chasing thumbnail preview --- */
.hover-thumb{
  position:fixed;
  top:0; left:0;
  width: 240px;
  aspect-ratio: 4/3;
  overflow:hidden;
  pointer-events:none;      /* it floats; the rows stay hoverable */
  z-index:9;
}
/* the IMAGE fades/zooms via CSS; the wrapper's position is GSAP's job —
   keeping the two transforms on separate elements avoids conflicts */
.hover-thumb img{
  width:100%; height:100%;
  object-fit:cover;
  opacity:0;
  transform: scale(.85);
  transition: opacity .35s ease, transform .45s cubic-bezier(0.22,1,0.36,1);
}
.hover-thumb.on img{ opacity:1; transform: scale(1); }
@media (max-width: 1024px){ .hover-thumb{ display:none; } }  /* touch screens: none */

/* the "See all" pill */
.btn-all{
  display:inline-block;
  margin-top: 40px;
  border:2px solid var(--cream);
  border-radius:100px;
  padding: 18px 46px;
  font-size:15px;
  letter-spacing:.14em;
  text-transform:uppercase;
  font-weight:700;
  transition: all .25s;
}
.btn-all:hover{ background:var(--cream); color:#111; }
/* the same pill inside the white statement section: black on white */
.statement .btn-all{ border-color: var(--black); color: var(--black); }
.statement .btn-all:hover{ background: var(--black); color: var(--cream); }

/* ============================================================
   TEXT-ROLL HOVER (global)
   JS wraps eligible link text like this:
     <span class="roll">              ← the mask (1 line tall)
       <span class="roll-inner">      ← 2 stacked copies, slides up
         <span class="roll-line">Text</span>
         <span class="roll-line">Text</span>
       </span>
     </span>
   On hover the inner column moves up by exactly one line (-50%
   of its own two-line height): the first copy exits through the
   top of the mask while the duplicate rises into place. Hover
   out and the CSS transition plays it backwards. No JS on hover.
   ============================================================ */
.roll{
  display:inline-block;
  overflow:hidden;               /* the mask */
  height:1.25em;                 /* exactly one line */
  line-height:1.25;              /* roomy enough for descenders (y, p, g) */
  vertical-align:top;
}
.roll-inner{
  display:block;
  transition: transform .45s cubic-bezier(0.22, 1, 0.36, 1);  /* the brand ease */
}
.roll-line{ display:block; height:1.25em; }
.has-roll:hover .roll-inner{ transform: translateY(-50%); }
/* accessibility: no rolling for reduced-motion users */
@media (prefers-reduced-motion: reduce){
  .roll-inner{ transition:none; }
  .has-roll:hover .roll-inner{ transform:none; }
}

/* --- MEDIA sub-blocks: "Video" and "Photos" subtitles --- */
.sub-head{
  display:flex;
  justify-content:space-between;
  align-items:baseline;
  margin: 100px 0 36px;
}
.sub-head.first{ margin-top: 0; }
.subtitle{
  font-family:'Inter Tight',sans-serif;
  font-weight:500;
  font-size: clamp(1.6rem, 3vw, 2.6rem);
  letter-spacing:-0.02em;
}

/* --- VIDEO: a straightforward 3-across grid --- */
.video-grid{
  display:grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.vid a{ display:block; }
.v-thumb{
  position:relative;
  display:block;
  aspect-ratio: 16/9;
  overflow:hidden;
}
.v-thumb img{ transition: transform .6s cubic-bezier(0.22,1,0.36,1); }
.vid:hover .v-thumb img{ transform: scale(1.04); }
.v-thumb .play{
  position:absolute;
  top:50%; left:50%;
  width:56px; height:56px;
  margin:-28px 0 0 -28px;
  border-radius:50%;
  background: rgba(255,248,240,.92);
  color:#111;
  display:flex; align-items:center; justify-content:center;
  font-size:15px;
}
.vid figcaption{
  margin-top:12px;
  font-size:11px;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:#9a9a9a;
}

/* tablet & below: swap links for the burger */
@media (max-width: 1024px){
  header nav a.nav-link{ display:none; }
  .burger{ display:block; }
  header .wordmark img{ height: 26px; }   /* smaller logo — room to breathe */
  header nav{ gap: 14px; }

  /* NEWS below 1024px: two-line rows. Top line = index + date,
     the headline gets the whole second line and may WRAP —
     rows simply grow taller. (The one-line hover roll is a
     desktop luxury; these are touch screens anyway.) */
  .news-row{
    grid-template-columns: 1fr;   /* date on top, headline below */
    row-gap: 8px;
  }
  .n-title{ grid-column: 1 / -1; grid-row: 2; }  /* full-width line 2 */
  .n-arrow{ display:none; }
  /* undo the one-line roll mask so headlines can wrap */
  .n-title .roll{ height:auto; white-space:normal; }
  .n-title .roll-line{ height:auto; }
  .n-title .roll-line + .roll-line{ display:none; }
}

/* ============================================================
   HOME / HERO — full-screen photo with cycling song titles,
   like the reference site's reel with cycling client names
   ============================================================ */
.hero{
  /* PINNED: the hero never scrolls. The page slides up OVER it
     (see .page-content below), while GSAP gently shrinks it. */
  position:fixed;
  top:0; left:0; width:100%;
  height: 100vh;
  overflow:hidden;
  z-index:0;                    /* bottom of the stack */
}
/* invisible stand-in that occupies the scroll distance the fixed
   hero no longer takes up — without it the page would jump */
.hero-spacer{ height:100vh; }
/* everything after the hero lives here: solid white and above the
   hero, so it covers it as it scrolls up */
.page-content{
  position:relative;
  z-index:2;
  background: var(--white);
}
/* SHEET 2: the statement (+ ticker) sticks to the top of the screen
   once reached — "sticky" means: scroll normally until you hit the
   top, then stay pinned there. The .cover block then slides over it,
