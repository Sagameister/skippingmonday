---
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { sanityClient, urlFor, isSanityConfigured } from '../lib/sanity';

// Check if Sanity is connected
const hasSanity = isSanityConfigured;
let heroSongs = [];
let featuredGigsForHero = [];
let featuredNewsForHero = [];
let featuredPhotosForHero = [];
let featuredVideosForHero = [];
let gigs = [];
let newsArticles = [];
let photos = [];
let videos = [];

const getEmbedSrc = (url) => {
  const ytReg = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
  const ytMatch = url ? url.match(ytReg) : null;
  const ytId = (ytMatch && ytMatch[2].length === 11) ? ytMatch[2] : null;

  const vimReg = /vimeo\.com\/(?:video\/)?([0-9]+)/;
  const vimMatch = url ? url.match(vimReg) : null;
  const vimId = vimMatch ? vimMatch[1] : null;

  if (ytId) return { type: 'youtube', id: ytId, src: `https://www.youtube.com/embed/${ytId}` };
  if (vimId) return { type: 'vimeo', id: vimId, src: `https://player.vimeo.com/video/${vimId}` };
  return null;
};

function formatGigDate(dateStr, lang) {
  if (!dateStr) return '';
  const parts = dateStr.split('-');
  if (parts.length !== 3) return '';
  const day = parseInt(parts[2], 10);
  const month = parseInt(parts[1], 10) - 1;
  const monthsEn = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  const monthsDe = ['Jan', 'Feb', 'März', 'Apr', 'Mai', 'Juni', 'Juli', 'Aug', 'Sep', 'Okt', 'Nov', 'Dez'];
  if (lang === 'de') {
    return `${day}. ${monthsDe[month]}`;
  }
  return `${monthsEn[month]} ${day}`;
}

function capitalizeTitle(str) {
  if (!str) return "";
  return str.toLowerCase().replace(/\b\w/g, c => c.toUpperCase());
}

if (hasSanity) {
  try {
    heroSongs = await sanityClient.fetch(`*[_type == "song" && isFeatured == true]`);
    featuredGigsForHero = await sanityClient.fetch(`*[_type == "post" && postType == "gig" && !isPast && isFeatured == true] | order(date asc)`);
    featuredNewsForHero = await sanityClient.fetch(`*[_type == "post" && postType == "news" && isFeatured == true] | order(date desc)`);
    featuredPhotosForHero = await sanityClient.fetch(`*[_type == "photo" && isFeatured == true]`);
    featuredVideosForHero = await sanityClient.fetch(`*[_type == "video" && isFeatured == true]`);
    
    gigs = await sanityClient.fetch(`*[_type == "post" && postType == "gig" && !isPast && isFeatured == true] | order(date asc)[0..4]`);
    if (!gigs || gigs.length === 0) {
      gigs = await sanityClient.fetch(`*[_type == "post" && postType == "gig" && !isPast] | order(date asc)[0..4]`);
    }
    
    newsArticles = await sanityClient.fetch(`*[_type == "post" && postType == "news" && isFeatured == true] | order(date desc)[0..4]`);
    if (!newsArticles || newsArticles.length === 0) {
      newsArticles = await sanityClient.fetch(`*[_type == "post" && postType == "news"] | order(date desc)[0..4]`);
    }
    
    photos = await sanityClient.fetch(`*[_type == "photo"] | order(orderRank asc)[0...6]`);
    videos = await sanityClient.fetch(`*[_type == "video"] | order(orderRank asc)[0...3]`);
  } catch (err) {
    console.error("Sanity fetch homepage data error:", err);
  }
}

if (!videos) videos = [];

// Prepare cycling song items for client script
let formattedSongs = [];
let sliderItems = [];

// 1. Add featured songs from CMS
if (heroSongs && heroSongs.length > 0) {
  sliderItems.push(...heroSongs.map(s => ({
    label: { en: s.categoryEn || 'Song', de: s.categoryDe || 'Song' },
    text: { en: s.titleEn, de: s.titleDe },
    image: s.coverImage ? urlFor(s.coverImage).url() : '/Images/hero.jpg'
  })));
}

// 2. Add featured gigs from CMS
if (featuredGigsForHero && featuredGigsForHero.length > 0) {
  sliderItems.push(...featuredGigsForHero.map(g => {
    const dateEn = formatGigDate(g.date, 'en');
    const dateDe = formatGigDate(g.date, 'de');
    const rawTitleEn = g.titleEn || `${g.city} — ${g.venue}`;
    const rawTitleDe = g.titleDe || g.titleEn || `${g.city} — ${g.venue}`;
    const titleEn = capitalizeTitle(rawTitleEn);
    const titleDe = capitalizeTitle(rawTitleDe);
    return {
      label: { en: 'Upcoming gig', de: 'Nächstes Konzert' },
      text: { 
        en: `${titleEn}${dateEn ? ` · ${dateEn}` : ''}`,
        de: `${titleDe}${dateDe ? ` · ${dateDe}` : ''}`
      },
      image: g.coverImage ? urlFor(g.coverImage).url() : '/Images/hero.jpg'
    };
  }));
}

// 3. Add featured news from CMS
if (featuredNewsForHero && featuredNewsForHero.length > 0) {
  sliderItems.push(...featuredNewsForHero.map(n => ({
    label: { en: 'Announcement', de: 'Ankündigung' },
    text: { en: n.titleEn, de: n.titleDe },
    image: n.coverImage ? urlFor(n.coverImage).url() : '/Images/hero.jpg'
  })));
}

// 4. Add featured photos from CMS
if (featuredPhotosForHero && featuredPhotosForHero.length > 0) {
  sliderItems.push(...featuredPhotosForHero.map(ph => ({
    label: { en: 'Photo', de: 'Foto' },
    text: { en: ph.captionEn, de: ph.captionDe },
    image: ph.image ? urlFor(ph.image).url() : '/Images/hero.jpg'
  })));
}

// 5. Add featured videos from CMS
if (featuredVideosForHero && featuredVideosForHero.length > 0) {
  sliderItems.push(...featuredVideosForHero.map(vid => {
    const embed = getEmbedSrc(vid.videoUrl);
    const ytThumb = (embed && embed.type === 'youtube') ? `https://img.youtube.com/vi/${embed.id}/maxresdefault.jpg` : '';
    const imgUrl = vid.thumbnail ? urlFor(vid.thumbnail).url() : (ytThumb || '/Images/hero.jpg');
    return {
      label: { en: 'Video', de: 'Video' },
      text: { en: vid.titleEn, de: vid.titleDe },
      image: imgUrl
    };
  }));
}

// Fallback to static items if no custom items are featured anywhere
if (sliderItems.length === 0) {
  formattedSongs = [
    { label: {en:'Upcoming gig',  de:'Nächstes Konzert'}, text: {en:'Berlin — Lido · Sep 12', de:'Berlin — Lido · 12. Sep'}, image: '/Images/hero.jpg' },
    { label: {en:'New release',   de:'Neue Single'}, text: {en:'“Call In Sad” — out now', de:'„Call In Sad“ — jetzt draußen'}, image: '/Images/hero.jpg' },
    { label: {en:'Announcement',  de:'Ankündigung'}, text: {en:'The No-Alarm Tour — 5 cities', de:'Die No-Alarm-Tour — 5 Städte'}, image: '/Images/hero.jpg' },
    { label: {en:'Upcoming gig',  de:'Nächstes Konzert'}, text: {en:'Hamburg — Molotow · Sep 19', de:'Hamburg — Molotow · 19. Sep'}, image: '/Images/hero.jpg' },
    { label: {en:'Announcement',  de:'Ankündigung'}, text: {en:'Köln is sold out — danke!', de:'Köln ist ausverkauft — danke!'}, image: '/Images/hero.jpg' }
  ];
} else {
  formattedSongs = sliderItems;
}

// Fallback for gigs
if (!gigs || gigs.length === 0) {
  gigs = [
    { date: '2026-09-12', city: 'Berlin', venue: 'Lido, Kreuzberg', ticketUrl: '#', soldOut: false },
    { date: '2026-09-19', city: 'Hamburg', venue: 'Molotow', ticketUrl: '#' },
    { date: '2026-09-26', city: 'Köln', venue: 'Gebäude 9', ticketUrl: '#', soldOut: true },
    { date: '2026-10-03', city: 'München', venue: 'Strom', ticketUrl: '#' },
    { date: '2026-10-10', city: 'Wien', venue: 'Flex', ticketUrl: '#' }
  ];
}

// Fallback for news
if (!newsArticles || newsArticles.length === 0) {
  newsArticles = [
    { _id: 'post-1', date: '2026-06-28', titleEn: '“Call In Sad” hits one million streams', titleDe: '„Call In Sad“ knackt eine Million Streams', staticThumb: 'https://picsum.photos/seed/newsstreams/480/360' },
    { _id: 'post-2', date: '2026-06-15', titleEn: 'Köln show sold out — second night under discussion', titleDe: 'Köln ausverkauft — zweite Show in Planung', staticThumb: 'https://picsum.photos/seed/newskoeln/480/360' },
    { _id: 'post-3', date: '2026-06-02', titleEn: 'Studio diary: week one of album two', titleDe: 'Studiotagebuch: Woche eins von Album zwei', staticThumb: 'https://picsum.photos/seed/newsstudio/480/360' },
    { _id: 'post-4', date: '2026-05-21', titleEn: 'The No-Alarm Tour announced — five cities', titleDe: 'Die No-Alarm-Tour angekündigt — fünf Städte', staticThumb: 'https://picsum.photos/seed/newstour/480/360' },
    { _id: 'post-5', date: '2026-05-09', titleEn: 'New merch: the Snooze Button hoodie', titleDe: 'Neuer Merch: der Snooze-Button-Hoodie', staticThumb: 'https://picsum.photos/seed/newsmerch/480/360' }
  ];
}

if (!photos) photos = [];

// Helper to format date to DD.MM.YYYY
function formatDate(dateStr: string) {
  const parts = dateStr.split('-');
  if (parts.length === 3) {
    return `${parts[2]}.${parts[1]}.${parts[0]}`;
  }
  return dateStr;
}
