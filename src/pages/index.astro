// --- Pattern 2: scroll reveals — fade up, once, then stay ------
gsap.from('.statement .sub', {
  scrollTrigger: { trigger: '.statement', start: 'top 80%', once: true },
  opacity: 0, y: 16, duration: 1, ease: 'brand', delay: .3
});

// ticker: the strip starts already filling the line edge-to-edge
// (no empty lead-in) and loops forever at a constant speed.
const tickerTrack = document.getElementById('ticker-track');
const TICKER_SPEED = 90;   // pixels per second — lower = calmer

let tickerTween = null;
const originalTickerHTML = tickerTrack ? tickerTrack.innerHTML : '';

function startTicker(){
  if (!tickerTrack) return;
  if (tickerTween) tickerTween.kill();
  
  // Restore track to its initial state to avoid infinite accumulation on resize
  tickerTrack.innerHTML = originalTickerHTML;
  
  const originalWidth = tickerTrack.scrollWidth;
  const originalContent = tickerTrack.innerHTML;
  
  // Duplicate content until the track is wider than the viewport + originalWidth
  while (tickerTrack.scrollWidth < window.innerWidth + originalWidth) {
    tickerTrack.innerHTML += originalContent;
  }
  
  // Now animate from 0 to -originalWidth
  tickerTween = gsap.to(tickerTrack, {
    x: -originalWidth,
    ease: 'none',
    duration: originalWidth / TICKER_SPEED,
    repeat: -1
  });
}
// fonts change the track's width — measure only after they're ready
document.fonts.ready.then(startTicker);
window.addEventListener('resize', startTicker);

// --- Pattern 6: staggered list — gigs cascade in ---------------
gsap.utils.toArray('.gig').forEach((row) => {
  gsap.from(row, {
    scrollTrigger: { trigger: row, start: 'top 95%', once: true },
    opacity: 0, y: 16, duration: .9, ease: 'brand'
  });
});

