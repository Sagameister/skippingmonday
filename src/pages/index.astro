<script is:inline define:vars={{ formattedSongs }}>
/* ---------- statement section colorful musical notes explosion ---------- */
(function() {
  const statementSection = document.querySelector('.statement');
  if (statementSection) {
    const noteSymbols = ['♩', '♪', '♫', '♬', '♭', '♮', '♯', '𝄞', '𝄢', '𝄡'];
    const colors = [
      '#e0115f', // deep pink / ruby
      '#0066ff', // electric blue
      '#ff5500', // vivid orange-red
      '#00a86b', // jade green
      '#8b00ff', // deep electric violet
      '#e60000', // bright crimson red
      '#ffaa00', // golden yellow
      '#00c0f0'  // dark cyan
    ];

    let audioCtx = null;
    function playRandomSynthNote() {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      }
      const scale = [220.00, 261.63, 293.66, 329.63, 392.00, 440.00, 523.25, 587.33, 659.25, 783.99, 880.00];
      const freq = scale[Math.floor(Math.random() * scale.length)];
      const osc = audioCtx.createOscillator();
      const filter = audioCtx.createBiquadFilter();
      const gainNode = audioCtx.createGain();

      osc.type = 'triangle';
      osc.frequency.setValueAtTime(freq, audioCtx.currentTime);

      filter.type = 'lowpass';
      filter.frequency.setValueAtTime(1000, audioCtx.currentTime);
      
      const now = audioCtx.currentTime;
      gainNode.gain.setValueAtTime(0, now);
      gainNode.gain.linearRampToValueAtTime(0.2, now + 0.05); 
      gainNode.gain.exponentialRampToValueAtTime(0.0001, now + 1.2);

      osc.connect(filter);
      filter.connect(gainNode);
      gainNode.connect(audioCtx.destination);

      osc.start(now);
      osc.stop(now + 1.25);
    }

    statementSection.addEventListener('click', (e) => {
      if (e.target.closest('a') || e.target.closest('button')) return;

      try {
        playRandomSynthNote();
      } catch (err) {
        console.error("Web Audio API error:", err);
      }

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const rect = statementSection.getBoundingClientRect();
      const clickX = e.clientX - rect.left;
      const clickY = e.clientY - rect.top;

      const numNotes = gsap.utils.random(16, 24, 1);
      for (let i = 0; i < numNotes; i++) {
        const note = document.createElement('div');
        note.className = 'note-particle';
        note.textContent = gsap.utils.random(noteSymbols);
        note.style.color = gsap.utils.random(colors);
        note.style.left = `${clickX}px`;
        note.style.top = `${clickY}px`;
        note.style.fontSize = `${gsap.utils.random(28, 64, 1)}px`;
        note.style.transform = `translate(-50%, -50%) rotate(${gsap.utils.random(-45, 45)}deg)`;
        
        statementSection.appendChild(note);

        const angle = gsap.utils.random(0, Math.PI * 2);
        const velocity = gsap.utils.random(120, 350);
        const xOffset = Math.cos(angle) * velocity;
        const yOffset = Math.sin(angle) * velocity;
        
        gsap.to(note, {
          x: xOffset,
          y: yOffset - gsap.utils.random(50, 150),
          rotation: gsap.utils.random(-360, 360),
          opacity: 0,
          scale: gsap.utils.random(0.4, 0.7),
          duration: gsap.utils.random(1.4, 2.2),
          ease: 'power2.out',
          onComplete: () => {
            note.remove();
          }
        });
      }
    });
  }
})();

/* ---------- page transitions (fade out on click, fade in on load) ---------- */
if (document.readyState === 'interactive' || document.readyState === 'complete') {
  document.body.classList.add('page-ready');
} else {
  document.addEventListener('DOMContentLoaded', () => {
    document.body.classList.add('page-ready');
  });
}

function wirePageTransitions() {
  document.querySelectorAll('a').forEach((link) => {
    const href = link.getAttribute('href');
    if (
      href &&
      !href.startsWith('#') &&
      !href.startsWith('mailto:') &&
      !href.startsWith('tel:') &&
      link.target !== '_blank' &&
      link.hostname === location.hostname
    ) {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        document.body.classList.remove('page-ready');
        setTimeout(() => {
          location.href = href;
        }, 350);
      });
    }
  });
}
wirePageTransitions();

window.addEventListener('pageshow', (event) => {
  if (event.persisted) {
    document.body.classList.add('page-ready');
  }
});

/* ============================================================
   MOTION SYSTEM SETUP
   Values come from the Motion Stack Guide:
   - one signature ease (soft deceleration, nothing bouncy)
   - small vertical-only movements (16–24px)
   - every reveal fires ONCE and stays
   - respect "prefers reduced motion" (an accessibility must)
   ============================================================ */
gsap.registerPlugin(ScrollTrigger, CustomEase);

// the guide's exact easing curve [0.22, 1, 0.36, 1], named "brand"
CustomEase.create('brand', '0.22, 1, 0.36, 1');

// true if the user asked their OS to minimize animations
const prefersReduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

/* ============================================================
   PART 0 — LENIS SMOOTH SCROLL
   Normal scrolling jumps in steps; Lenis catches your scroll
   and "glides" the page instead. We also connect it to GSAP's
   ScrollTrigger so scroll animations stay perfectly in sync.
   ============================================================ */
let lenis = null;
// only smooth-scroll if the library loaded AND the user is okay with motion
if (window.Lenis && !prefersReduced) {
  lenis = new Lenis({
    duration: 1.2,            // how long the glide lasts (higher = floatier)
    smoothWheel: true         // smooth the mouse wheel too
  });

  // every time Lenis scrolls, tell ScrollTrigger "we moved!"
  lenis.on('scroll', ScrollTrigger.update);

  // Use the standard high-performance requestAnimationFrame loop for Lenis
  function raf(time) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  // Expose globally
  window.lenis = lenis;
}

/* --- header theme: white over the hero photo, black after it --- */
const headerEl = document.querySelector('header');
// the hero is FIXED, so its rectangle never moves — we watch the
// spacer instead (it scrolls normally, standing in for the hero)
const heroSpacer = document.querySelector('.hero-spacer');

const coverEl = document.querySelector('.cover');

function updateHeaderTheme(){
  const probe = 80;   // the height (px) where the navbar text sits
  // three vertical zones pass under the navbar as you scroll:
  //   1. dark hero photo      → white navbar
  //   2. white statement      → black navbar
  //   3. dark cover sections  → white navbar again
  const heroBottom = heroSpacer.getBoundingClientRect().bottom;
  const coverTop   = coverEl.getBoundingClientRect().top;
  const overStatement = heroBottom < probe && coverTop > probe;
  headerEl.classList.toggle('dark', overStatement && !menuVisible);
}
addEventListener('scroll', updateHeaderTheme, { passive: true });
addEventListener('resize', updateHeaderTheme);

/* --- burger menu (tablet/mobile) --- */
const burgerBtn   = document.querySelector('.burger');
const menuOverlay = document.querySelector('.menu-overlay');
let menuOpen    = false;   // is the menu logically open?
let menuVisible = false;   // is the black curtain still on screen? (stays
                           // true during the closing animation)

function openMenu(){
  menuOpen = menuVisible = true;
  burgerBtn.classList.add('open');
  burgerBtn.setAttribute('aria-label', 'Close menu');
  if (lenis) lenis.stop();                    // freeze page scrolling behind the menu
  headerEl.classList.remove('dark');          // white bar over the black menu

  // stop any half-finished open/close animation before starting a new one
  gsap.killTweensOf([menuOverlay, '.menu-overlay .m-inner']);

  if (prefersReduced){                        // no motion: appear instantly
    gsap.set(menuOverlay, { yPercent: 0, autoAlpha: 1 });
    gsap.set('.menu-overlay .m-inner', { yPercent: 0 });
    return;
  }
  // 1. the curtain slides down over the page...
  gsap.set(menuOverlay, { autoAlpha: 1 });    // make it visible first
  gsap.to(menuOverlay, { yPercent: 0, duration: .8, ease: 'brand' });
  // 2. ...then the big links rise out of their masks, one after another
  gsap.fromTo('.menu-overlay .m-inner',
    { yPercent: 110 },
    { yPercent: 0, duration: .9, ease: 'brand', stagger: .08, delay: .3 });
}

function closeMenu(){
  if (!menuOpen) return;
  menuOpen = false;
  burgerBtn.classList.remove('open');
  burgerBtn.setAttribute('aria-label', 'Open menu');
  if (lenis) lenis.start();                   // let the page scroll again

  gsap.killTweensOf([menuOverlay, '.menu-overlay .m-inner']);

  if (prefersReduced){                        // no motion: vanish instantly
    gsap.set(menuOverlay, { y: 0, yPercent: -100, autoAlpha: 0 });
    menuVisible = false;
    updateHeaderTheme();
    return;
  }
  // 1. the links dip back down into their masks (quick)...
  gsap.to('.menu-overlay .m-inner', {
    yPercent: 110, duration: .35, ease: 'brand', stagger: .04
  });
  // 2. ...then the curtain lifts away, and only THEN do we hide it
  gsap.to(menuOverlay, {
    yPercent: -100, duration: .7, ease: 'brand', delay: .15,
    onComplete: () => {
      gsap.set(menuOverlay, { autoAlpha: 0 });
      menuVisible = false;                    // curtain fully gone...
      updateHeaderTheme();                    // ...now the navbar may flip theme
    }
  });
}
burgerBtn.addEventListener('click', () => menuOpen ? closeMenu() : openMenu());

// menu links: glide to the section instead of jumping
document.querySelectorAll('a[href^="#"]').forEach((link) => {
  link.addEventListener('click', (e) => {
    const target = link.getAttribute('href');     // e.g. "#gigs"
    if (target.length > 1) {                      // ignore plain "#" links
      e.preventDefault();                         // stop the instant jump
      closeMenu();                                // if the overlay menu is open, shut it
      if (lenis) {
        lenis.scrollTo(target, { duration: 1.4 });          // glide there (Lenis)
      } else {
        document.querySelector(target)                       // fallback: browser glide
                .scrollIntoView({ behavior: 'smooth' });
      }
    }
  });
});

/* ============================================================
   PART 1 — LANGUAGE SWITCHER (DE / EN)
   How it works: any element that should translate carries two
   attributes, data-en="..." and data-de="...".
   Clicking DE or EN copies the right one into the element.
   ============================================================ */
function setLang(lang){                      // lang is 'en' or 'de'
  // find every element that has a data-en attribute...
  document.querySelectorAll('[data-en]').forEach((el) => {
    el.textContent = el.dataset[lang];       // ...and swap its text
  });
  // swapping text wipes out the word-masks inside headlines AND
  // the hover-roll wrappers — rebuild both for the new language
  refreshSplits();
  buildAllRolls();
  // switcher: big button shows the NEW language, dropdown offers the other
  const other = lang === 'en' ? 'de' : 'en';
  langCurrentBtn.textContent = lang.toUpperCase();
  langOptBtn.textContent = other.toUpperCase();
  langOptBtn.dataset.lang = other;
  langWrap.classList.remove('open');                    // fold the menu away
  langCurrentBtn.setAttribute('aria-expanded', 'false');
  document.documentElement.lang = lang;      // good practice for screen readers
  currentLang = lang;
  try { localStorage.setItem('sm-lang', lang); } catch(e){}  // remember across pages
}
let currentLang = 'en';
const langWrap       = document.querySelector('.lang');
const langCurrentBtn = document.getElementById('lang-current');
const langOptBtn     = document.getElementById('lang-opt');

// tap the visible language → open/close the little dropdown
langCurrentBtn.addEventListener('click', (e) => {
  e.stopPropagation();                     // don't let the page click below close it instantly
  const open = langWrap.classList.toggle('open');
  langCurrentBtn.setAttribute('aria-expanded', String(open));
});
// pick the other language → switch everything
langOptBtn.addEventListener('click', () => setLang(langOptBtn.dataset.lang));
// clicking anywhere else closes the dropdown
addEventListener('click', (e) => {
  if (!langWrap.contains(e.target)){
    langWrap.classList.remove('open');
    langCurrentBtn.setAttribute('aria-expanded', 'false');
  }
});

/* ============================================================
   PART 2 — ROTATING HERO INFO
   Cycles through upcoming gigs, new releases, and announcements.
   Each item has a small label (the type) and a big title, and
   each carries BOTH languages so the DE/EN switcher always works.
   ============================================================ */

const heroItems = formattedSongs;
let heroIndex = 0;
const titleEl     = document.getElementById('cycle-title');
const heroLabelEl = document.getElementById('cycle-label');

// put one item on screen (optionally with the word-mask animation)
function renderHeroItem(animated){
  const item = heroItems[heroIndex];
  // store both languages ON the elements — setLang() reads these,
  // so switching DE/EN mid-rotation shows the right text
  heroLabelEl.dataset.en = item.label.en;  heroLabelEl.dataset.de = item.label.de;
  titleEl.dataset.en     = item.text.en;   titleEl.dataset.de     = item.text.de;

  heroLabelEl.textContent = item.label[currentLang];
  titleEl.textContent     = item.text[currentLang];

  // Dynamic background image crossfade
  const bg1 = document.getElementById('hero-bg-1');
  const bg2 = document.getElementById('hero-bg-2');
  if (bg1 && bg2) {
    const nextBg = bg1.classList.contains('active') ? bg2 : bg1;
    const currentBg = bg1.classList.contains('active') ? bg1 : bg2;

    const img = new Image();
    img.src = item.image || '/Images/hero.jpg';
    img.onload = () => {
      nextBg.src = img.src;
      nextBg.classList.add('active');
      currentBg.classList.remove('active');
    };
  }

  if (!animated || prefersReduced) return;    // plain text is enough
  splitWords(titleEl);                        // wrap each word in a mask
  gsap.fromTo(titleEl.querySelectorAll('.w-inner'),
    { yPercent: 110 },                        // start: hidden below the mask
    { yPercent: 0, duration: .9, ease: 'brand', stagger: .06 });
}

function nextHeroItem(){
  heroIndex = (heroIndex + 1) % heroItems.length;   // loop 0,1,2,3,4,0...
  if (prefersReduced){ renderHeroItem(false); return; }
  // old words exit UP through the mask, then the new item enters from below
  gsap.to(titleEl.querySelectorAll('.w-inner'), {
    yPercent: -110, duration: .5, ease: 'brand', stagger: .04,
    onComplete: () => renderHeroItem(true)
  });
}
setInterval(nextHeroItem, 4000);   // rotate every 4 seconds — unhurried

/* ============================================================
   PART 3 — SUBTLE 3D DUST (three.js)
   A faint field of drifting gray specks behind the headline.
   Barely there — that's the point on a minimal site.
   ============================================================ */
const canvas = document.getElementById('dust-canvas');
const holder = canvas.parentElement;                     // the .statement block

const scene    = new THREE.Scene();
const camera   = new THREE.PerspectiveCamera(60, 1, 0.1, 100);
camera.position.z = 10;
const renderer = new THREE.WebGLRenderer({ canvas, alpha:true, antialias:true });
renderer.setPixelRatio(Math.min(devicePixelRatio, 2));

// size the canvas to its section (not the whole window)
function sizeDust(){
  const w = holder.clientWidth, h = holder.clientHeight;
  renderer.setSize(w, h);
  camera.aspect = w / h;
  camera.updateProjectionMatrix();
}
sizeDust();
addEventListener('resize', sizeDust);

// Helper to create a texture of a musical note symbol drawn on a canvas
function createNoteTexture(char, blur) {
  const canvas = document.createElement('canvas');
  canvas.width = 128;
  canvas.height = 128;
  const ctx = canvas.getContext('2d');

  // Draw note in the center
  ctx.font = '64px sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = '#999999';

  // Apply shadow blur to simulate depth of field (blurry far away, sharp up close)
  if (blur > 0) {
    ctx.shadowColor = 'rgba(153, 153, 153, 0.7)';
    ctx.shadowBlur = blur;
  }

  ctx.fillText(char, 64, 64);
  return new THREE.CanvasTexture(canvas);
}

// Generate textures for different depths (blurry, medium, crisp)
const noteChars = ['♩', '♪', '♫', '♬'];
const textures = {
  crisp: noteChars.map(char => createNoteTexture(char, 0)),
  medium: noteChars.map(char => createNoteTexture(char, 4)),
  blurry: noteChars.map(char => createNoteTexture(char, 12))
};

// Create a group of sprites
const sprites = [];
const COUNT = 120;

for (let i = 0; i < COUNT; i++) {
  // Set random position in a 3D bounding area
  const x = (Math.random() - 0.5) * 24;
  const y = (Math.random() - 0.5) * 12;
  const z = (Math.random() - 0.5) * 8; // z depth field

  let textureList;
  let opacity;
  let scale;

  // Distribute textures, opacities, and sizes based on Z-depth (made a little larger and brighter)
  if (z < -1.5) {
    textureList = textures.blurry;
    opacity = 0.15 + (Math.random() * 0.15); // far back: blurry, subtle glow
    scale = 0.45 + (Math.random() * 0.2);    // slightly larger blurred notes
  } else if (z > 1.5) {
    textureList = textures.crisp;
    opacity = 0.5 + (Math.random() * 0.15);  // up close: sharp, bright
    scale = 0.2 + (Math.random() * 0.1);     // middle size sharp notes
  } else {
    textureList = textures.medium;
    opacity = 0.35 + (Math.random() * 0.15); // midground: balanced
    scale = 0.3 + (Math.random() * 0.15);
  }

  // Pick a random musical note character
  const randomTexture = textureList[Math.floor(Math.random() * textureList.length)];

  const material = new THREE.SpriteMaterial({
    map: randomTexture,
    transparent: true,
    opacity: opacity,
    color: 0x8a8a8a
  });

  const sprite = new THREE.Sprite(material);
  sprite.position.set(x, y, z);
  sprite.scale.set(scale, scale, 1);

  // Store original positions and random drift multipliers
  sprite.userData = {
    homeX: x,
    homeY: y,
    homeZ: z,
    angle: Math.random() * Math.PI * 2,
    speed: 0.1 + Math.random() * 0.3,
    orbitRadius: 0.2 + Math.random() * 0.4
  };

  scene.add(sprite);
  sprites.push(sprite);
}

// Gentle drift + interactive cursor magnetic physics
let mx = 0, my = 0;
let mouseInsideSection = false;

const statementEl = document.querySelector('.statement');
if (statementEl) {
  statementEl.addEventListener('mouseenter', () => {
    mouseInsideSection = true;
  });
  statementEl.addEventListener('mouseleave', () => {
    mouseInsideSection = false;
  });
  statementEl.addEventListener('mousemove', (e) => {
    const rect = statementEl.getBoundingClientRect();
    mx = (e.clientX - rect.left) / rect.width - 0.5;
    my = (e.clientY - rect.top) / rect.height - 0.5;
  });
}

const clock = new THREE.Clock();
if (prefersReduced) {
  renderer.render(scene, camera); // render static layout once if motion is disabled
} else {
  (function animate(){
    requestAnimationFrame(animate);
    const t = clock.getElapsedTime();

    // Map 2D mouse coordinates (-0.5 to 0.5) to approximate 3D world coordinates
    const mouse3D = {
      x: mx * 20,
      y: -my * 10
    };

    sprites.forEach((sprite) => {
      const data = sprite.userData;

      // Orbiting drift (slightly faster, smooth floating motion)
      const driftX = Math.sin(t * 1.0 * data.speed + data.angle) * data.orbitRadius;
      const driftY = Math.cos(t * 0.8 * data.speed + data.angle) * data.orbitRadius;
      const targetX = data.homeX + driftX;
      const targetY = data.homeY + driftY;

      // Easing destination based on mouse state (gravitate directly to cursor if inside)
      let destinationX = targetX;
      let destinationY = targetY;

      if (mouseInsideSection) {
        // Gravitate to cursor, but retain 25% of their home spread to prevent total overlapping blobs
        destinationX = mouse3D.x + data.homeX * 0.25;
        destinationY = mouse3D.y + data.homeY * 0.25;
      }

      // Smoothly ease position toward the destination (slow, magnetic glide)
      sprite.position.x += (destinationX - sprite.position.x) * 0.035;
      sprite.position.y += (destinationY - sprite.position.y) * 0.035;
    });

    // Subtly tilt/rotate the scene based on mouse for 3D parallax depth
    scene.rotation.y = mx * 0.15;
    scene.rotation.x = my * 0.1;

    renderer.render(scene, camera);
  })();
}

/* ============================================================
   PART 4 — SCROLL & LOAD ANIMATIONS (GSAP)
   Tuned to the Motion Stack Guide:
   ease 'brand' · vertical only · once:true · unhurried
   Headlines use MASK REVEALS: every word rises out of a hidden
   "slot" (see the .w-mask CSS at the top of the file).
   ============================================================ */

// --- The split-text engine -------------------------------------
// Wraps every word of an element in <span class="w-mask"><span class="w-inner">
function splitWords(el){
  const words = el.textContent.trim().split(/\s+/);   // "We never play" → 3 words
  el.innerHTML = '';                                  // empty the element...
  words.forEach((word, i) => {
    const mask  = document.createElement('span');     // the letterbox
    mask.className = 'w-mask';
    const inner = document.createElement('span');     // the part that moves
    inner.className = 'w-inner';
    inner.textContent = word;
    mask.appendChild(inner);
    el.appendChild(mask);
    if (i < words.length - 1) el.appendChild(document.createTextNode(' '));
  });
}

const splitEls = gsap.utils.toArray('[data-split]');  // all marked headlines

// (re)build the masks — also called after every language switch
function refreshSplits(){
  if (prefersReduced) return;                 // reduced motion: leave plain text
  splitEls.forEach((el) => {
    splitWords(el);
    // headlines that haven't animated yet start hidden below their masks
    if (!el.classList.contains('revealed')){
      gsap.set(el.querySelectorAll('.w-inner'), { yPercent: 110 });
    }
  });
}

// slide a headline's words up into view, one after another
function revealSplit(el){
  gsap.to(el.querySelectorAll('.w-inner'), {
    yPercent: 0, duration: 1.2, ease: 'brand', stagger: 0.08,
    delay: parseFloat(el.dataset.splitDelay || 0),
    onComplete: () => el.classList.add('revealed')   // remember: already shown
  });
}

if (!prefersReduced) {   // skip ALL decorative motion if the user opted out

// build the masks and arm one scroll trigger per headline.
// The animation targets are looked up at FIRE time (onEnter), so a
// language switch before the reveal doesn't break anything.
refreshSplits();
splitEls.forEach((el) => {
  ScrollTrigger.create({
    trigger: el, start: 'top 85%', once: true,
    onEnter: () => revealSplit(el)
  });
});

// --- Pattern 1: hero entrance ---------------------------------
// photo starts slightly larger and settles at 1.12 — it stays
// oversized on purpose, so the parallax below never shows gaps
gsap.fromTo('.hero img', { scale: 1.18 }, { scale: 1.12, duration: 1.4, ease: 'brand' });
// "Now playing" label: opacity-only, settles at 70% (Pattern 7)
gsap.fromTo('.hero .cycle .micro', { opacity: 0 }, { opacity: .7, duration: .8, ease: 'brand', delay: .3 });
gsap.delayedCall(.4, () => renderHeroItem(true));  // first hero item mask-reveals in

// --- Pattern 5: hero parallax — photo drifts while being covered.
// All hero scroll effects are driven by the SPACER's progress,
// because the fixed hero itself never moves.
gsap.to('.hero-bg-img', {
  scrollTrigger: { trigger: '.hero-spacer', start: 'top top', end: 'bottom top', scrub: true },
  yPercent: 6, ease: 'none'   // the 1.12 oversize gives it room to move
});

// --- the pinned-hero shrink: as the page slides over the hero,
// the hero scales down to 92% and gains soft rounded corners,
// like a card being covered by a sheet of paper
gsap.to('.hero', {
