.cover .clock-row{ border-bottom-color: rgba(255,248,240,.18); }
.cover .clock-row time{ color: #9a9a9a; }
.cover .foot-grid ul a:hover{ color: #9a9a9a; }
.cover svg.giant path{ fill: var(--cream); }
.cover /* --- mailing list signup (footer) --- */
