---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient, urlFor, isSanityConfigured } from '../lib/sanity';

// Check if Sanity is connected
const hasSanity = isSanityConfigured;
let videos = [];
let photos = [];

if (hasSanity) {
  try {
    videos = await sanityClient.fetch(`*[_type == "video"] | order(orderRank asc)`);
    photos = await sanityClient.fetch(`*[_type == "photo"] | order(orderRank asc)`);
  } catch (err) {
    console.error("Sanity fetch error for media:", err);
  }
}

if (!videos) videos = [];
if (!photos) photos = [];
---
<BaseLayout title="Media — Skipping Mondays">
  <!-- ===================== PAGE HERO ===================== -->
  <div class="page-hero">
    <img src="/Images/media-hero.jpg" alt="Skipping Mondays bassist and singer live on stage">
    <h1 class="page-title" data-split data-en="Media" data-de="Medien">Media</h1>
  </div>

  <main class="page-main">
    <div class="sub-head first">
      <h3 class="subtitle" data-split data-en="Videos" data-de="Videos">Videos</h3>
    </div>
    {(() => {
      const getEmbedSrc = (url) => {
        const ytReg = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
        const ytMatch = url ? url.match(ytReg) : null;
        const ytId = (ytMatch && ytMatch[2].length === 11) ? ytMatch[2] : null;

        const vimReg = /vimeo\.com\/(?:video\/)?([0-9]+)/;
        const vimMatch = url ? url.match(vimReg) : null;
        const vimId = vimMatch ? vimMatch[1] : null;

        if (ytId) return { type: 'youtube', id: ytId, src: `https://www.youtube.com/embed/${ytId}` };
        if (vimId) return { type: 'vimeo', id: vimId, src: `https://player.vimeo.com/video/${vimId}` };
        return null;
      };

      const parsedVideos = videos.map(vid => ({
        ...vid,
        embed: getEmbedSrc(vid.videoUrl)
      })).filter(vid => vid.embed !== null);

      if (parsedVideos.length === 0) return null;
      
      const initialVideo = parsedVideos[0];
      const initialSrc = initialVideo.embed.src;
      
      return (
        <div class="video-hub">
          <div class="video-main-player">
            <div class="v-embed-wrapper">
              <iframe 
                class="main-video-iframe" 
                style="border: 0; outline: none; width: 100%; height: 100%; position: absolute; top: 0; left: 0;"
                title={initialVideo.titleEn}
                src={initialSrc} 
                allow="autoplay; encrypted-media" 
                allowfullscreen
              ></iframe>
            </div>
            <div class="video-main-info">
              <h4 class="main-video-title" data-en={initialVideo.titleEn} data-de={initialVideo.titleDe}>{initialVideo.titleEn}</h4>
            </div>
          </div>
          
          <div class="video-playlist">
            <div class="playlist-header">
              <span class="playlist-title" data-en="Videos" data-de="Videos">Videos</span>
              <span class="video-count">{parsedVideos.length} {parsedVideos.length === 1 ? 'Video' : 'Videos'}</span>
            </div>
            <div class="playlist-items">
              {parsedVideos.map((vid, idx) => {
                const thumbUrl = vid.thumbnail ? urlFor(vid.thumbnail).url() : (vid.embed.type === 'youtube' ? `https://img.youtube.com/vi/${vid.embed.id}/mqdefault.jpg` : vid.staticImage);
                return (
                  <button 
                    class={`playlist-item ${idx === 0 ? 'active' : ''}`}
                    data-index={idx}
                    data-src={vid.embed.src}
                    data-title-en={vid.titleEn}
                    data-title-de={vid.titleDe}
                    aria-label={`Play: ${vid.titleEn}`}
                  >
                    <div class="playlist-thumb">
                      <img src={thumbUrl} alt={vid.titleEn} />
                      <span class="play-overlay">▶</span>
                    </div>
                    <div class="playlist-meta">
                      <span class="item-title" data-en={vid.titleEn} data-de={vid.titleDe}>{vid.titleEn}</span>
                      <span class="item-playing" data-en="Now Playing" data-de="Wird abgespielt">Now Playing</span>
                    </div>
                  </button>
                );
              })}
            </div>
          </div>
        </div>
      );
    })()}

    <div class="sub-head">
      <h3 class="subtitle" data-split data-en="Photos" data-de="Fotos">Photos</h3>
    </div>
    <div class="photo-wall">
      {photos.map((ph) => {
        const imgUrl = ph.image ? urlFor(ph.image).url() : ph.staticImage;
        return (
          <figure class="reveal-img photo-item" style="cursor: pointer;">
            <img src={imgUrl} alt={ph.captionEn || ''} />
            <figcaption data-en={ph.captionEn || ''} data-de={ph.captionDe || ph.captionEn || ''}>{ph.captionEn || ''}</figcaption>
          </figure>
        );
      })}
    </div>
  </main>

  <!-- Lightbox Modal -->
  <div id="lightbox-modal" class="lightbox" aria-hidden="true" role="dialog">
    <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
    <button class="lightbox-arrow lightbox-prev" aria-label="Previous photo">&#10094;</button>
    <div class="lightbox-content">
      <img id="lightbox-img" src="" alt="" />
      <div id="lightbox-caption" class="lightbox-caption"></div>
    </div>
    <button class="lightbox-arrow lightbox-next" aria-label="Next photo">&#10095;</button>
  </div>
</BaseLayout>
